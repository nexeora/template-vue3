{
  "name": "@nekaii/new-template-vue3-tslib",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/main.js"
    },
    "./main.css": "./dist/main.css"
  },
  "sideEffects": "./**/*.css",
