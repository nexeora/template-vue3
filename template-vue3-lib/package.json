    "@vueuse/math": "^14.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "vite-plugin-prettier-format": "^1.0.0",
    "unplugin-dts": "^1.0.2",
    "terser": "^5.48.0",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@types/jake": "^0.0.39",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "jake": "^12.10.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
